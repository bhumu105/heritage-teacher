# Copy this to .env.local and fill in real values.
# .env.local is gitignored — it will never leave your machine.

# Supabase — Project Settings → API
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=

# Secrets below are NOT used by the frontend — they belong in Supabase Edge
# Function secrets (set via `supabase secrets set`). Listed here for reference only.
# SUPABASE_SERVICE_ROLE_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
